{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": ".",
    "paths": {
      "db": ["../../packages/db/src/index.ts"], // Point directly to the source entry
      "db/*": ["../../packages/db/*"],
      "@/*": ["./src/*"]
    },
    // Add this to allow "outside" files
    "rootDirs": ["src", "../../packages/db/src"],
    "module": "NodeNext", // Supports modern resolution
    "moduleResolution": "NodeNext", // Helps find types in monorepo packages
    "target": "ES2020",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": false
  },
  "include": ["src/**/*", "../../packages/db/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
